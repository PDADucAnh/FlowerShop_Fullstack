@model UpdatePromotionCampaignDTO
@{
    ViewData["Title"] = "Sửa đợt khuyến mãi";
    Layout = "_LayoutAdmin";
    var productIdsStr = Model.ProductIds != null ? string.Join(", ", Model.ProductIds) : "";
}

<div class="space-y-lg max-w-4xl mx-auto">
    <div class="flex justify-between items-center">
        <div>
            <h3 class="text-label-sm uppercase tracking-[0.3em] text-secondary">Khuyến mãi</h3>
            <p class="serif text-3xl font-bold">Sửa đợt khuyến mãi</p>
        </div>
        <a asp-action="Index" class="text-label-sm uppercase tracking-widest font-bold flex items-center gap-2 hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            Quay lại
        </a>
    </div>

    <form asp-action="Edit" method="post" class="bg-surface-container-lowest border border-outline-variant p-xl space-y-xl">
        <input asp-for="Id" type="hidden" />

        <div class="space-y-md">
            <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Tên chiến dịch</label>
            <input asp-for="Name" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 serif text-2xl font-bold placeholder:text-outline-variant" required />
            <span asp-validation-for="Name" class="text-error text-xs uppercase tracking-widest"></span>
        </div>

        <div class="space-y-md">
            <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Mô tả</label>
            <textarea asp-for="Description" rows="3" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 text-body-md italic leading-relaxed placeholder:text-outline-variant"></textarea>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Loại khuyến mãi</label>
                <select asp-for="PromotionType" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3">
                    <option value="FlashSale">Flash Sale</option>
                    <option value="Seasonal">Theo mùa</option>
                </select>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Loại giảm giá</label>
                <select asp-for="DiscountType" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3">
                    <option value="Percent">Phần trăm (%)</option>
                    <option value="FixedAmount">Số tiền cố định</option>
                </select>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Giá trị giảm</label>
                <input asp-for="DiscountValue" type="number" step="0.01" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" required />
                <span asp-validation-for="DiscountValue" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Độ ưu tiên</label>
                <input asp-for="Priority" type="number" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" />
            </div>
            <div class="space-y-md flex items-end">
                <label class="flex items-center gap-2 cursor-pointer">
                    <input asp-for="IsStackable" type="checkbox" class="w-5 h-5 rounded border-outline-variant text-primary focus:ring-primary/20" />
                    <span class="font-body-md text-body-md text-on-surface">Có thể kết hợp với mã giảm giá</span>
                </label>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Bắt đầu</label>
                <input asp-for="StartDate" type="datetime-local" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" />
                <span asp-validation-for="StartDate" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Kết thúc</label>
                <input asp-for="EndDate" type="datetime-local" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" />
                <span asp-validation-for="EndDate" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
        </div>

        <div class="space-y-md">
            <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">ID sản phẩm (phân cách bằng dấu phẩy)</label>
            <input name="productIdsCsv" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" value="@productIdsStr" placeholder="1, 2, 3" />
        </div>

        <div class="space-y-md">
            <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Hình ảnh banner</label>
            <input asp-for="BannerImage" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" placeholder="/uploads/banners/flash-sale.jpg" />
        </div>

        <div class="pt-lg border-t border-outline-variant flex gap-md">
            <button type="submit" class="bg-primary text-on-primary px-xl py-4 text-label-sm uppercase tracking-[0.2em] font-bold hover:bg-neutral-800 transition-all flex-1">
                Cập nhật
            </button>
            <a asp-action="Index" class="border border-outline px-xl py-4 text-label-sm uppercase tracking-[0.2em] font-bold hover:bg-surface-container transition-all">
                Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
