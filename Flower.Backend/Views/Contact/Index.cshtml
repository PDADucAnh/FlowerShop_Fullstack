@model IEnumerable<ContactDTO>
@{
    ViewData["Title"] = "Liên hệ";
    Layout = "_LayoutAdmin";
}

<div class="space-y-lg max-w-6xl mx-auto">
    <div class="flex justify-between items-center">
        <div>
            <h3 class="text-label-sm uppercase tracking-[0.3em] text-secondary">Tiếp nhận</h3>
            <p class="serif text-3xl font-bold">Liên hệ từ khách hàng</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-lg py-3 rounded-lg">@TempData["Success"]</div>
    }

    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden">
        <table class="w-full">
            <thead>
                <tr class="border-b border-outline-variant/30 text-label-sm uppercase tracking-widest text-secondary">
                    <th class="text-left px-lg py-4">Người gửi</th>
                    <th class="text-left px-lg py-4">Chủ đề</th>
                    <th class="text-left px-lg py-4">Email</th>
                    <th class="text-center px-lg py-4">Trạng thái</th>
                    <th class="text-right px-lg py-4">Ngày gửi</th>
                    <th class="text-right px-lg py-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="border-b border-outline-variant/15 @(!item.IsRead ? "bg-secondary-container/10" : "")">
                        <td class="px-lg py-4 font-medium">@item.Name</td>
                        <td class="px-lg py-4">@item.Subject</td>
                        <td class="px-lg py-4 text-secondary">@item.Email</td>
                        <td class="px-lg py-4 text-center">
                            @if (!item.IsRead)
                            {
                                <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">Mới</span>
                            }
                            else
                            {
                                <span class="bg-surface-container-high text-secondary px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">Đã xem</span>
                            }
                        </td>
                        <td class="px-lg py-4 text-right text-secondary">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="px-lg py-4 text-right">
                            <a asp-action="Detail" asp-route-id="@item.Id" class="text-primary hover:underline text-label-sm font-bold uppercase tracking-wider">Xem</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="text-error hover:underline text-label-sm font-bold uppercase tracking-wider ml-lg" onclick="return confirm('Xóa liên hệ này?')">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
