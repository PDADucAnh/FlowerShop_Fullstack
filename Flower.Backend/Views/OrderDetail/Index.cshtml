@model IEnumerable<OrderDetailDTO>
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "_LayoutAdmin";
}

<div class="space-y-lg">
    <div class="flex justify-between items-center">
        <div>
            <h3 class="text-label-sm uppercase tracking-[0.3em] text-secondary">Chi tiết đơn hàng</h3>
            <p class="serif text-3xl font-bold">Sản phẩm trong đơn hàng</p>
        </div>
        <a asp-action="Create" class="bg-primary text-on-primary px-lg py-3 text-label-sm uppercase tracking-widest flex items-center gap-2 hover:bg-neutral-800 transition-all">
            <span class="material-symbols-outlined text-lg">add</span>
            Thêm sản phẩm
        </a>
    </div>

    <div class="bg-surface-container-lowest border border-outline-variant overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-outline-variant text-label-sm uppercase text-secondary tracking-widest bg-surface-container-low">
                        <th class="px-lg py-4">Mã chi tiết</th>
                        <th class="px-lg py-4">Đơn hàng</th>
                        <th class="px-lg py-4">Sản phẩm</th>
                        <th class="px-lg py-4">Số lượng</th>
                        <th class="px-lg py-4 text-right">Đơn giá</th>
                        <th class="px-lg py-4 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant">
                    @foreach (var od in Model)
                    {
                        <tr class="table-row-hover transition-colors">
                            <td class="px-lg py-5 serif font-bold">#DT-@od.Id</td>
                            <td class="px-lg py-5 text-label-sm tracking-widest uppercase">#ORD-@od.OrderId</td>
                            <td class="px-lg py-5">
                                <div class="flex flex-col">
                                    <span class="text-body-md font-bold">@(od.ProductName ?? "N/A")</span>
                                    <span class="text-[10px] text-secondary uppercase tracking-widest">Khách hàng: @(od.CustomerName ?? "N/A")</span>
                                </div>
                            </td>
                            <td class="px-lg py-5 text-body-md">@od.Quantity</td>
                            <td class="px-lg py-5 text-right font-bold">@od.UnitPrice.ToString("C2")</td>
                            <td class="px-lg py-5 text-right space-x-4">
                                <a asp-action="Edit" asp-route-id="@od.Id" class="text-label-sm uppercase tracking-widest font-bold text-secondary">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@od.Id" class="text-label-sm uppercase tracking-widest font-bold text-error" onclick="return confirm('Xóa bản ghi này?')">Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <partial name="_Pagination" />
</div>
