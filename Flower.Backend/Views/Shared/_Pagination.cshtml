@{
    var totalPages = (int)ViewData["TotalPages"];
    var currentPage = (int)ViewData["CurrentPage"];
    var totalCount = (int)ViewData["TotalCount"];
    var pageSize = (int)ViewData["PageSize"];
    var action = (string)(ViewData["PaginationAction"] ?? "Index");
    var controller = (string)(ViewData["PaginationController"] ?? ViewContext.RouteData.Values["controller"]?.ToString());
    var extraParams = (string)ViewData["PaginationExtraParams"];

    var getUrl = (int page) => {
        var qs = $"?page={page}&pageSize={pageSize}";
        if (!string.IsNullOrEmpty(extraParams))
            qs += "&" + extraParams.TrimStart('&');
        return Url.Action(action, controller) + qs;
    };

    var getPages = () => {
        var pages = new List<dynamic>();
        var delta = 2;
        var start = Math.Max(2, currentPage - delta);
        var end = Math.Min(totalPages - 1, currentPage + delta);

        pages.Add(new { type = "page", value = 1 });
        if (start > 2) pages.Add(new { type = "ellipsis", value = 0 });
        for (int i = start; i <= end; i++)
            pages.Add(new { type = "page", value = i });
        if (end < totalPages - 1) pages.Add(new { type = "ellipsis", value = 0 });
        if (totalPages > 1) pages.Add(new { type = "page", value = totalPages });

        return pages;
    };
}

@if (totalPages > 1)
{
    <div class="px-lg py-4 border-t border-outline-variant/20 flex items-center justify-between bg-surface-container-lowest">
        <span class="font-label-sm text-label-sm text-on-surface-variant">
            Hiển thị @((currentPage - 1) * pageSize + 1)-@Math.Min(currentPage * pageSize, totalCount) trên tổng số @totalCount bản ghi
        </span>
        <div class="flex gap-1">
            <a href="@getUrl(currentPage - 1)"
               class="p-1 rounded-md text-on-surface-variant hover:bg-surface-variant transition-colors flex items-center justify-center @(currentPage <= 1 ? "disabled pointer-events-none opacity-40" : "")"
               aria-label="Trang trước">
                <span class="material-symbols-outlined">chevron_left</span>
            </a>

            @foreach (var p in getPages())
            {
                if (p.type == "ellipsis")
                {
                    <span class="w-8 h-8 flex items-center justify-center font-label-sm text-label-sm text-on-surface-variant">...</span>
                }
                else
                {
                    <a href="@getUrl(p.value)"
                       class="w-8 h-8 rounded-md flex items-center justify-center font-label-sm text-label-sm transition-colors @(p.value == currentPage ? "bg-primary text-on-primary shadow-sm" : "text-on-surface-variant hover:bg-surface-variant")">
                        @p.value
                    </a>
                }
            }

            <a href="@getUrl(currentPage + 1)"
               class="p-1 rounded-md text-on-surface-variant hover:bg-surface-variant transition-colors flex items-center justify-center @(currentPage >= totalPages ? "disabled pointer-events-none opacity-40" : "")"
               aria-label="Trang sau">
                <span class="material-symbols-outlined">chevron_right</span>
            </a>
        </div>
    </div>
}
