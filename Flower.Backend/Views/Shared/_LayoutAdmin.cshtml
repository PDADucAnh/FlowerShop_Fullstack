<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FlowerShop Admin</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&amp;family=Plus+Jakarta+Sans:wght@400;500;600&amp;display=swap" rel="stylesheet" />
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "outline-variant": "#ddbfc5",
                        "on-primary-fixed": "#3f001b",
                        "surface-container-highest": "#e4e2e1",
                        "primary-fixed": "#ffd9e1",
                        "secondary": "#6b5a60",
                        "surface-tint": "#ab2c5d",
                        "on-primary-container": "#5e002b",
                        "on-primary": "#ffffff",
                        "on-tertiary-fixed": "#1a1c1c",
                        "on-secondary": "#ffffff",
                        "inverse-primary": "#ffb1c5",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-low": "#f6f3f2",
                        "secondary-fixed": "#f4dce4",
                        "surface-bright": "#fbf9f8",
                        "tertiary-fixed": "#e2e2e2",
                        "surface-dim": "#dcd9d9",
                        "on-error-container": "#93000a",
                        "on-secondary-fixed-variant": "#524249",
                        "surface-variant": "#e4e2e1",
                        "inverse-surface": "#303030",
                        "surface": "#fbf9f8",
                        "primary-fixed-dim": "#ffb1c5",
                        "surface-container-high": "#eae8e7",
                        "tertiary": "#5d5f5f",
                        "tertiary-container": "#939494",
                        "inverse-on-surface": "#f3f0f0",
                        "tertiary-fixed-dim": "#c6c6c7",
                        "on-error": "#ffffff",
                        "primary": "#ab2c5d",
                        "on-surface-variant": "#574146",
                        "secondary-container": "#f4dce4",
                        "error-container": "#ffdad6",
                        "on-secondary-fixed": "#25181e",
                        "primary-container": "#f06292",
                        "secondary-fixed-dim": "#d7c1c8",
                        "error": "#ba1a1a",
                        "on-tertiary": "#ffffff",
                        "on-secondary-container": "#716066",
                        "background": "#fbf9f8",
                        "surface-container": "#f0eded",
                        "on-primary-fixed-variant": "#8b0e45",
                        "outline": "#8a7176",
                        "on-background": "#1b1c1c",
                        "on-surface": "#1b1c1c",
                        "on-tertiary-fixed-variant": "#454747",
                        "on-tertiary-container": "#2b2d2d"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "stack-lg": "48px",
                        "stack-md": "24px",
                        "container-max": "1280px",
                        "margin-desktop": "40px",
                        "margin-mobile": "20px",
                        "stack-sm": "12px",
                        "gutter": "24px",
                        "base": "8px",
                        "lg": "2rem",
                        "xl": "4rem",
                        "sm": "1rem",
                        "md": "1.5rem",
                        "xs": "0.5rem",
                        "margin": "2rem"
                    },
                    "fontFamily": {
                        "display-lg-mobile": ["Playfair Display"],
                        "headline-md": ["Playfair Display"],
                        "label-md": ["Plus Jakarta Sans"],
                        "body-lg": ["Plus Jakarta Sans"],
                        "headline-sm": ["Playfair Display"],
                        "body-md": ["Plus Jakarta Sans"],
                        "label-sm": ["Plus Jakarta Sans"],
                        "display-lg": ["Playfair Display"]
                    },
                    "fontSize": {
                        "display-lg-mobile": ["32px", { "lineHeight": "1.2", "fontWeight": "700" }],
                        "headline-md": ["32px", { "lineHeight": "1.3", "fontWeight": "600" }],
                        "label-md": ["14px", { "lineHeight": "1.4", "letterSpacing": "0.05em", "fontWeight": "600" }],
                        "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "headline-sm": ["24px", { "lineHeight": "1.3", "fontWeight": "600" }],
                        "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "label-sm": ["12px", { "lineHeight": "1.4", "fontWeight": "500" }],
                        "display-lg": ["48px", { "lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700" }]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .shadow-petal {
            box-shadow: 0 4px 20px -2px rgba(171, 44, 93, 0.05);
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .field-validation-error { color: #ba1a1a; font-size: 0.875rem; }
        .input-validation-error { border-color: #ba1a1a !important; }
    </style>
</head>
<body class="bg-surface text-on-surface h-screen w-full overflow-hidden flex selection:bg-primary-container selection:text-on-primary-container">
    <!-- Sidebar -->
    <aside class="fixed left-0 top-0 h-full flex flex-col p-stack-sm border-r border-outline-variant/20 bg-surface-container-low w-64 z-20">
        <!-- Header -->
        <div class="px-4 py-stack-md flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center text-primary overflow-hidden">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">local_florist</span>
            </div>
            <div>
                <h1 class="font-headline-sm text-headline-sm text-primary tracking-tight">Admin Panel</h1>
                <p class="font-label-sm text-label-sm text-on-surface-variant">Management Suite</p>
            </div>
        </div>
        <!-- CTA -->
        <div class="px-2 mb-stack-md">
            <a asp-controller="Product" asp-action="Create" class="w-full bg-primary text-on-primary py-3 rounded-lg font-label-md shadow-petal hover:shadow-md transition-all active:scale-95 flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[18px]">add</span>
                Add New Arrangement
            </a>
        </div>
        <!-- Main Nav -->
        <nav class="flex-1 space-y-1 px-2 overflow-y-auto no-scrollbar">
            <!-- Dashboard -->
            <a class="flex items-center gap-3 px-4 py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "text-primary bg-secondary-container rounded-lg" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 rounded-lg group"
               asp-controller="Home" asp-action="Index">
                <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "" : "group-hover:scale-110") transition-transform" @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "style=font-variation-settings:'FILL' 1" : "")>dashboard</span>
                <span class="font-label-md text-label-md">Dashboard</span>
            </a>

            <div class="px-4 pt-4 pb-1">
                <p class="text-[10px] text-on-surface-variant uppercase tracking-[0.2em] font-bold">Shop</p>
            </div>
            <!-- Inventory (Products) -->
            <a class="flex items-center gap-3 px-4 py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "text-primary bg-secondary-container rounded-lg" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 rounded-lg group"
               asp-controller="Product" asp-action="Index">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">local_florist</span>
                <span class="font-label-md text-label-md">Inventory</span>
            </a>
            <!-- Product Categories -->
            <a class="flex items-center gap-3 px-4 py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "CategoryProduct" ? "text-primary bg-secondary-container rounded-lg" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 rounded-lg group"
               asp-controller="CategoryProduct" asp-action="Index">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">category</span>
                <span class="font-label-md text-label-md">Collections</span>
            </a>
            <!-- Orders -->
            <a class="flex items-center gap-3 px-4 py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "text-primary bg-secondary-container rounded-lg" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 rounded-lg group"
               asp-controller="Order" asp-action="Index">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">shopping_cart</span>
                <span class="font-label-md text-label-md">Orders</span>
            </a>
            <!-- Order Details -->
            <a class="flex items-center gap-3 px-4 py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "OrderDetail" ? "text-primary bg-secondary-container rounded-lg" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 rounded-lg group"
               asp-controller="OrderDetail" asp-action="Index">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">receipt_long</span>
                <span class="font-label-md text-label-md">Order Details</span>
            </a>
            <!-- Customers -->
            <a class="flex items-center gap-3 px-4 py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "text-primary bg-secondary-container rounded-lg" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 rounded-lg group"
               asp-controller="Customer" asp-action="Index">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">group</span>
                <span class="font-label-md text-label-md">Customers</span>
            </a>

            <div class="px-4 pt-4 pb-1">
                <p class="text-[10px] text-on-surface-variant uppercase tracking-[0.2em] font-bold">Blog</p>
            </div>
            <!-- Blog Categories -->
            <a class="flex items-center gap-3 px-4 py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "text-primary bg-secondary-container rounded-lg" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 rounded-lg group"
               asp-controller="Category" asp-action="Index">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">grid_view</span>
                <span class="font-label-md text-label-md">Blog Categories</span>
            </a>
            <!-- Posts -->
            <a class="flex items-center gap-3 px-4 py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Post" ? "text-primary bg-secondary-container rounded-lg" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 rounded-lg group"
               asp-controller="Post" asp-action="Index">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">article</span>
                <span class="font-label-md text-label-md">Posts</span>
            </a>

            <div class="px-4 pt-4 pb-1">
                <p class="text-[10px] text-on-surface-variant uppercase tracking-[0.2em] font-bold">System</p>
            </div>
            <!-- Admin Users -->
            <a class="flex items-center gap-3 px-4 py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "text-primary bg-secondary-container rounded-lg" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 rounded-lg group"
               asp-controller="User" asp-action="Index">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">manage_accounts</span>
                <span class="font-label-md text-label-md">Admin Users</span>
            </a>
        </nav>
        <!-- Sidebar Footer -->
        <div class="mt-auto px-2 pb-4 space-y-1 border-t border-outline-variant/20 pt-4">
            <a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:text-primary hover:bg-primary-container/20 transition-all duration-200 rounded-lg" href="#">
                <span class="material-symbols-outlined">help</span>
                <span class="font-label-md text-label-md">Help Center</span>
            </a>
            @if (User.Identity.IsAuthenticated)
            {
                <a asp-controller="Account" asp-action="Logout" class="flex items-center gap-3 px-4 py-2 text-error hover:bg-error-container transition-all duration-200 rounded-lg">
                    <span class="material-symbols-outlined">logout</span>
                    <span class="font-label-md text-label-md">Log Out</span>
                </a>
            }
        </div>
    </aside>

    <!-- Main Area -->
    <div class="ml-64 flex-1 flex flex-col h-screen overflow-hidden bg-surface">
        <!-- Top Nav -->
        <header class="flex justify-between items-center px-margin-desktop w-full border-b border-outline-variant/30 bg-surface h-16 shadow-sm z-10 shrink-0">
            <div class="flex items-center flex-1">
                <div class="relative w-64">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
                    <input class="w-full bg-surface-container-low border border-outline-variant/30 rounded-full py-2 pl-10 pr-4 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors text-on-surface placeholder:text-on-surface-variant/70" placeholder="Search orders, customers..." type="text" />
                </div>
            </div>
            <div class="font-headline-sm text-headline-sm text-primary hidden lg:block">
                FlowerShop Admin
            </div>
            <div class="flex items-center gap-4 flex-1 justify-end">
                <button class="p-2 text-on-surface-variant hover:bg-surface-container-low transition-colors rounded-full relative cursor-pointer active:opacity-80">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute top-1 right-2 w-2 h-2 bg-error rounded-full"></span>
                </button>
                <button class="p-2 text-on-surface-variant hover:bg-surface-container-low transition-colors rounded-full cursor-pointer active:opacity-80">
                    <span class="material-symbols-outlined">settings</span>
                </button>
                <div class="h-8 w-px bg-outline-variant/50 mx-2"></div>
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="flex items-center gap-2 p-1 pr-3 rounded-full">
                        <div class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center text-primary font-bold text-sm">
                            @(User.FindFirst("FullName")?.Value?.Substring(0, 1).ToUpper() ?? "A")
                        </div>
                        <span class="font-label-sm text-on-surface">@(User.FindFirst("FullName")?.Value ?? "Admin")</span>
                    </div>
                }
            </div>
        </header>

        <!-- Content Area -->
        <main class="flex-1 overflow-y-auto p-margin-desktop bg-surface-bright/50">
            @RenderBody()
        </main>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
