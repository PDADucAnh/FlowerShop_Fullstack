<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FlowerShop Admin</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <!-- CKEditor 5 -->
    <script src="https://cdn.ckeditor.com/ckeditor5/41.0.0/classic/ckeditor.js"></script>
    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "outline-variant": "#ddbfc5",
                        "on-primary-fixed": "#3f001b",
                        "surface-container-highest": "#e4e2e1",
                        "primary-fixed": "#ffd9e1",
                        "secondary": "#6b5a60",
                        "surface-tint": "#ab2c5d",
                        "on-primary-container": "#5e002b",
                        "on-primary": "#ffffff",
                        "on-tertiary-fixed": "#1a1c1c",
                        "on-secondary": "#ffffff",
                        "inverse-primary": "#ffb1c5",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-low": "#f6f3f2",
                        "secondary-fixed": "#f4dce4",
                        "surface-bright": "#fbf9f8",
                        "tertiary-fixed": "#e2e2e2",
                        "surface-dim": "#dcd9d9",
                        "on-error-container": "#93000a",
                        "on-secondary-fixed-variant": "#524249",
                        "surface-variant": "#e4e2e1",
                        "inverse-surface": "#303030",
                        "surface": "#fbf9f8",
                        "primary-fixed-dim": "#ffb1c5",
                        "surface-container-high": "#eae8e7",
                        "tertiary": "#5d5f5f",
                        "tertiary-container": "#939494",
                        "inverse-on-surface": "#f3f0f0",
                        "tertiary-fixed-dim": "#c6c6c7",
                        "on-error": "#ffffff",
                        "primary": "#ab2c5d",
                        "on-surface-variant": "#574146",
                        "secondary-container": "#f4dce4",
                        "error-container": "#ffdad6",
                        "on-secondary-fixed": "#25181e",
                        "primary-container": "#f06292",
                        "secondary-fixed-dim": "#d7c1c8",
                        "error": "#ba1a1a",
                        "on-tertiary": "#ffffff",
                        "on-secondary-container": "#716066",
                        "background": "#fbf9f8",
                        "surface-container": "#f0eded",
                        "on-primary-fixed-variant": "#8b0e45",
                        "outline": "#8a7176",
                        "on-background": "#1b1c1c",
                        "on-surface": "#1b1c1c",
                        "on-tertiary-fixed-variant": "#454747",
                        "on-tertiary-container": "#2b2d2d"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "stack-lg": "48px",
                        "stack-md": "24px",
                        "container-max": "1280px",
                        "margin-desktop": "40px",
                        "margin-mobile": "20px",
                        "stack-sm": "12px",
                        "gutter": "24px",
                        "base": "8px",
                        "xl": "4rem",
                        "lg": "2rem",
                        "md": "1.5rem",
                        "sm": "1rem",
                        "xs": "0.5rem",
                        "margin": "2rem"
                    },
                    "fontFamily": {
                        "display-lg-mobile": ["Playfair Display"],
                        "headline-md": ["Playfair Display"],
                        "label-md": ["Plus Jakarta Sans"],
                        "body-lg": ["Plus Jakarta Sans"],
                        "headline-sm": ["Playfair Display"],
                        "body-md": ["Plus Jakarta Sans"],
                        "label-sm": ["Plus Jakarta Sans"],
                        "display-lg": ["Playfair Display"]
                    },
                    "fontSize": {
                        "display-lg-mobile": ["32px", { "lineHeight": "1.2", "fontWeight": "700" }],
                        "headline-md": ["32px", { "lineHeight": "1.3", "fontWeight": "600" }],
                        "label-md": ["14px", { "lineHeight": "1.4", "letterSpacing": "0.05em", "fontWeight": "600" }],
                        "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "headline-sm": ["24px", { "lineHeight": "1.3", "fontWeight": "600" }],
                        "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "label-sm": ["12px", { "lineHeight": "1.4", "fontWeight": "500" }],
                        "display-lg": ["48px", { "lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700" }]
                    }
                }
            }
        }
    </script>
    <style>
        .petal-shadow-1 {
            box-shadow: 0 4px 20px rgba(171, 44, 93, 0.04);
        }
        .petal-shadow-2 {
            box-shadow: 0 8px 30px rgba(171, 44, 93, 0.08);
        }
        .ambient-bg {
            background-image: radial-gradient(circle at top right, rgba(255, 217, 225, 0.3) 0%, transparent 40%),
                              radial-gradient(circle at bottom left, rgba(244, 220, 228, 0.4) 0%, transparent 50%);
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .field-validation-error { color: #ba1a1a; font-size: 0.875rem; }
        .input-validation-error { border-color: #ba1a1a !important; }
        .serif { font-family: 'Playfair Display', serif; }
    </style>
</head>
<body class="bg-background text-on-background font-body-md text-body-md ambient-bg min-h-screen flex">
    <!-- Sidebar Navigation -->
    <nav class="fixed left-0 top-0 h-full flex flex-col p-stack-sm border-r border-outline-variant/20 bg-surface-container-low h-screen w-64 z-20">
        <div class="px-base py-stack-md flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-on-primary text-lg font-bold">
                <span class="material-symbols-outlined">local_florist</span>
            </div>
            <div>
                <h1 class="font-headline-sm text-headline-sm text-primary tracking-tight leading-tight">Admin</h1>
                <p class="font-label-sm text-label-sm text-on-surface-variant">Quản trị</p>
            </div>
        </div>

        <div class="px-base mb-stack-md">
            <a asp-controller="Product" asp-action="Create" class="w-full flex items-center justify-center gap-2 bg-primary text-on-primary py-3 rounded-lg font-label-md text-label-md petal-shadow-1 hover:bg-primary/90 transition-colors no-underline">
                <span class="material-symbols-outlined text-[20px]">add</span>
                Tạo nhanh
            </a>
        </div>

        <div class="flex-1 overflow-y-auto space-y-1 px-base no-scrollbar">
            @{
                var controller = ViewContext.RouteData.Values["controller"]?.ToString();
            }

            <p class="text-[10px] text-on-surface-variant uppercase tracking-[0.2em] font-medium px-4 pt-2 pb-1">Bảng điều khiển</p>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Home" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Home" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Home" ? "text-primary" : "")">dashboard</span>
                Bảng điều khiển
            </a>

            <p class="text-[10px] text-on-surface-variant uppercase tracking-[0.2em] font-medium px-4 pt-4 pb-1">Danh mục sản phẩm</p>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Product" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Product" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Product" ? "text-primary" : "")">local_florist</span>
                Sản phẩm
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "CategoryProduct" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="CategoryProduct" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "CategoryProduct" ? "text-primary" : "")">category</span>
                Danh mục sản phẩm
            </a>

            <p class="text-[10px] text-on-surface-variant uppercase tracking-[0.2em] font-medium px-4 pt-4 pb-1">Bán hàng</p>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Order" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Order" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Order" ? "" : "")" style="@(controller == "Order" ? "font-variation-settings: 'FILL' 1;" : "")">shopping_cart</span>
                Đơn hàng
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "OrderDetail" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="OrderDetail" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "OrderDetail" ? "text-primary" : "")">receipt_long</span>
                Chi tiết đơn hàng
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Customer" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Customer" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Customer" ? "text-primary" : "")">group</span>
                Khách hàng
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Contact" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Contact" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Contact" ? "text-primary" : "")">mail</span>
                Liên hệ
            </a>

            <p class="text-[10px] text-on-surface-variant uppercase tracking-[0.2em] font-medium px-4 pt-4 pb-1">Nội dung</p>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Post" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Post" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Post" ? "text-primary" : "")">article</span>
                Bài viết
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Category" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Category" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Category" ? "text-primary" : "")">grid_view</span>
                Danh mục blog
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Page" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Page" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Page" ? "text-primary" : "")">description</span>
                Trang
            </a>

            <p class="text-[10px] text-on-surface-variant uppercase tracking-[0.2em] font-medium px-4 pt-4 pb-1">Tiếp thị</p>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Promotion" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Promotion" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Promotion" ? "text-primary" : "")">local_offer</span>
                Khuyến mãi
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Coupon" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Coupon" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Coupon" ? "text-primary" : "")">confirmation_number</span>
                Mã giảm giá
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Advertisement" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Advertisement" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Advertisement" ? "text-primary" : "")">campaign</span>
                Quảng cáo
            </a>

            <p class="text-[10px] text-on-surface-variant uppercase tracking-[0.2em] font-medium px-4 pt-4 pb-1">Hệ thống</p>
            @if (User.IsInRole("Admin"))
            {
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "User" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
                   asp-controller="User" asp-action="Index">
                    <span class="material-symbols-outlined @(controller == "User" ? "text-primary" : "")">manage_accounts</span>
                    Người dùng
                </a>
            }
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Settings" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Settings" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Settings" ? "text-primary" : "")">settings</span>
                Cấu hình
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md @(controller == "Notification" ? "text-primary bg-secondary-container" : "text-on-surface-variant hover:text-primary hover:bg-primary-container/20") transition-all duration-200 no-underline"
               asp-controller="Notification" asp-action="Index">
                <span class="material-symbols-outlined @(controller == "Notification" ? "text-primary" : "")">notifications</span>
                Thông báo
            </a>
        </div>

        <div class="mt-auto px-base pt-stack-md border-t border-outline-variant/20 space-y-1">
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md text-on-surface-variant hover:text-primary hover:bg-primary-container/20 transition-all duration-200 no-underline" href="#">
                <span class="material-symbols-outlined">help</span>
                Trợ giúp
            </a>
            @if (User.Identity.IsAuthenticated)
            {
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg font-label-md text-label-md text-on-surface-variant hover:text-primary hover:bg-primary-container/20 transition-all duration-200 no-underline" asp-controller="Account" asp-action="Logout">
                    <span class="material-symbols-outlined">logout</span>
                    Đăng xuất
                </a>
            }
        </div>
    </nav>

    <!-- Main Content Canvas -->
    <main class="ml-64 flex-1 flex flex-col min-h-screen">
        <!-- Top Header -->
        <header class="flex justify-between items-center px-margin-desktop w-full h-16 shadow-sm bg-surface">
            <div class="md:hidden font-headline-sm text-headline-sm text-primary">FlowerShop Admin</div>
            <div class="hidden md:block"></div>

            <div class="hidden md:flex flex-1 max-w-md mx-8">
                <div class="relative w-full">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">search</span>
                    <input class="w-full pl-10 pr-4 py-2 bg-surface-container-low border border-outline-variant/30 rounded-full focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary font-body-md text-body-md text-on-surface transition-colors placeholder:text-on-surface-variant/70" placeholder="Tìm đơn hàng..." type="text" />
                </div>
            </div>

            <div class="flex items-center gap-4">
                <!-- Notification Bell & Dropdown -->
                <div class="relative" id="notification-bell-container">
                    <button id="notification-bell-btn" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-low transition-colors text-on-surface-variant border-0 bg-transparent cursor-pointer relative">
                        <span class="material-symbols-outlined">notifications</span>
                        <!-- Unread badge -->
                        <span id="notification-badge" class="absolute top-1.5 right-1.5 w-4 h-4 bg-error text-on-error text-[10px] font-bold flex items-center justify-center rounded-full hidden">0</span>
                    </button>
                    <!-- Dropdown Panel -->
                    <div id="notification-dropdown" class="absolute right-0 mt-2 w-80 bg-surface rounded-2xl petal-shadow-2 border border-outline-variant/30 hidden z-50 overflow-hidden">
                        <div class="p-4 border-b border-outline-variant/20 flex justify-between items-center bg-surface-container-lowest">
                            <h4 class="font-headline-sm text-sm font-bold text-on-surface">Thông báo</h4>
                            <button id="mark-all-read-btn" class="text-xs text-primary hover:underline bg-transparent border-0 cursor-pointer font-label-sm">Đã đọc tất cả</button>
                        </div>
                        <div id="notification-list" class="max-h-64 overflow-y-auto divide-y divide-outline-variant/10">
                            <div class="p-4 text-center text-on-surface-variant text-xs">Không có thông báo mới</div>
                        </div>
                        <div class="p-3 border-t border-outline-variant/20 text-center bg-surface-container-lowest">
                            <a asp-controller="Notification" asp-action="Index" class="text-xs text-primary font-bold hover:underline no-underline">Xem tất cả thông báo</a>
                        </div>
                    </div>
                </div>
                
                <a asp-controller="Settings" asp-action="Index" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-low transition-colors text-on-surface-variant border-0 bg-transparent cursor-pointer no-underline">
                    <span class="material-symbols-outlined">settings</span>
                </a>
                <div class="w-px h-6 bg-outline-variant/30 mx-2"></div>
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="flex items-center gap-2 hover:bg-surface-container-low p-1 pr-3 rounded-full transition-colors border border-outline-variant/20">
                        <div class="w-8 h-8 rounded-full bg-secondary-container flex items-center justify-center text-primary font-headline-sm text-sm font-bold">
                            @(User.FindFirst("FullName")?.Value?.Length >= 2 ? User.FindFirst("FullName")?.Value?.Substring(0, 2).ToUpper() : "AD")
                        </div>
                        <span class="font-label-md text-label-md text-on-surface hidden sm:block">@User.FindFirst("FullName")?.Value</span>
                    </div>
                }
            </div>
        </header>

        <!-- Page Content -->
        <div class="p-margin-desktop flex-1 max-w-container-max mx-auto w-full">
            @if (TempData["Success"] != null)
            {
                <div class="mb-stack-md p-4 bg-[#E8F5E9] border border-[#A5D6A7]/50 text-[#2E7D32] font-label-md text-label-md rounded-lg flex items-center gap-3">
                    <span class="material-symbols-outlined text-lg">check_circle</span>
                    @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="mb-stack-md p-4 bg-error-container border border-error/20 text-error font-label-md text-label-md rounded-lg flex items-center gap-3">
                    <span class="material-symbols-outlined text-lg">error</span>
                    @TempData["Error"]
                </div>
            }
            @RenderBody()
        </div>

        <!-- Footer -->
        <footer class="border-t border-outline-variant/20 flex flex-col md:flex-row justify-between items-center px-margin-desktop py-6 gap-4 bg-surface-container-lowest">
            <p class="font-label-sm text-label-sm text-on-surface-variant">&copy; @DateTime.Now.Year FlowerShop. Đã đăng ký bản quyền.</p>
            <div class="flex gap-6">
                <a class="font-label-sm text-label-sm text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Tài liệu</a>
                <a class="font-label-sm text-label-sm text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Hỗ trợ</a>
                <a class="font-label-sm text-label-sm text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Điều khoản dịch vụ</a>
            </div>
        </footer>
    </main>

    <!-- Idle Timeout Modal -->
    <div id="idle-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/40 backdrop-blur-sm">
        <div class="bg-surface rounded-2xl petal-shadow-2 p-8 max-w-sm w-full mx-4 text-center animate-in" style="animation: fadeInUp 0.3s ease-out;">
            <div class="w-14 h-14 rounded-full bg-error-container flex items-center justify-center mx-auto mb-4">
                <span class="material-symbols-outlined text-error text-3xl">timer_off</span>
            </div>
            <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">Phiên sắp hết hạn</h3>
            <p class="font-body-md text-body-md text-on-surface-variant mb-1">
                Phiên làm việc của bạn sắp hết hạn do không hoạt động.
            </p>
            <p class="font-body-md text-body-md text-on-surface-variant mb-6">
                Bạn sẽ bị đăng xuất sau <strong id="idle-countdown" class="text-error">60</strong> giây.
            </p>
            <div class="flex gap-3 justify-center">
                <button id="idle-stay-btn"
                        class="px-6 py-2.5 bg-primary text-on-primary rounded-lg font-label-md text-label-md hover:bg-primary/90 transition-colors border-0 cursor-pointer">
                    Giữ phiên đăng nhập
                </button>
                <a id="idle-logout-btn"
                   class="px-6 py-2.5 bg-transparent text-on-surface-variant rounded-lg font-label-md text-label-md border border-outline-variant hover:bg-surface-container-low transition-colors no-underline"
                   asp-controller="Account" asp-action="Logout">
                    Đăng xuất ngay
                </a>
            </div>
        </div>
    </div>

    <style>
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        .animate-in { animation: fadeInUp 0.3s ease-out; }
    </style>

    <script>
        (function() {
            // === CONFIG ===
            const IDLE_TIMEOUT_MS = 15 * 60 * 1000;
            const COUNTDOWN_SECONDS = 60;

            let idleTimer = null;
            let countdownTimer = null;
            let secondsRemaining = COUNTDOWN_SECONDS;

            const modal = document.getElementById('idle-modal');
            const countdownEl = document.getElementById('idle-countdown');
            const stayBtn = document.getElementById('idle-stay-btn');
            const logoutBtn = document.getElementById('idle-logout-btn');

            function resetIdleTimer() {
                if (idleTimer) clearTimeout(idleTimer);
                if (modal.classList.contains('hidden')) {
                    idleTimer = setTimeout(showWarning, IDLE_TIMEOUT_MS);
                }
            }

            function showWarning() {
                modal.classList.remove('hidden');
                secondsRemaining = COUNTDOWN_SECONDS;
                countdownEl.textContent = secondsRemaining;
                countdownTimer = setInterval(function() {
                    secondsRemaining--;
                    countdownEl.textContent = secondsRemaining;
                    if (secondsRemaining <= 0) {
                        clearInterval(countdownTimer);
                        window.location.href = logoutBtn.getAttribute('href');
                    }
                }, 1000);
            }

            function stayLoggedIn() {
                if (countdownTimer) clearInterval(countdownTimer);
                modal.classList.add('hidden');
                resetIdleTimer();
            }

            stayBtn.addEventListener('click', stayLoggedIn);

            ['mousemove', 'keydown', 'click', 'scroll', 'touchstart'].forEach(function(ev) {
                document.addEventListener(ev, resetIdleTimer, { passive: true });
            });

            resetIdleTimer();
        })();
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('textarea[data-rich-editor]').forEach(function (el) {
                var type = el.getAttribute('data-rich-editor');
                var toolbar;
                if (type === 'full') {
                    toolbar = ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', '|', 'blockQuote', 'insertTable', '|', 'undo', 'redo', 'imageUpload'];
                } else {
                    toolbar = ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', '|', 'blockQuote', '|', 'undo', 'redo'];
                }
                ClassicEditor.create(el, { toolbar: toolbar }).catch(console.error);
            });
        });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script>
        (function() {
            // === Notification Bell System ===
            const badge = document.getElementById('notification-badge');
            const dropdown = document.getElementById('notification-dropdown');
            const bellBtn = document.getElementById('notification-bell-btn');
            const listContainer = document.getElementById('notification-list');
            const markAllBtn = document.getElementById('mark-all-read-btn');

            async function updateUnreadCount() {
                try {
                    const res = await fetch('/Notification/GetUnreadCount');
                    const data = await res.json();
                    if (data.count > 0) {
                        badge.textContent = data.count;
                        badge.classList.remove('hidden');
                    } else {
                        badge.classList.add('hidden');
                    }
                } catch (e) {
                    console.error('Failed to load notifications count', e);
                }
            }

            async function loadLatestNotifications() {
                try {
                    const res = await fetch('/Notification/GetLatest');
                    const notifications = await res.json();
                    listContainer.innerHTML = '';

                    if (notifications.length === 0) {
                        listContainer.innerHTML = '<div class="p-4 text-center text-on-surface-variant text-xs">Không có thông báo mới</div>';
                        return;
                    }

                    notifications.forEach(n => {
                        const date = new Date(n.createdAt);
                        const timeStr = date.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }) + ' ' + date.toLocaleDateString('vi-VN');
                        const isReadClass = n.isRead ? 'opacity-60 bg-transparent' : 'bg-primary-container/10 font-medium';
                        
                        const item = document.createElement('div');
                        item.className = `p-4 transition-colors hover:bg-surface-container-low flex flex-col gap-1 cursor-pointer ${isReadClass}`;
                        item.innerHTML = `
                            <div class="flex justify-between items-start gap-2">
                                <span class="text-xs font-bold text-primary uppercase tracking-wider text-[10px] bg-primary-container/20 px-1.5 py-0.5 rounded">${n.type}</span>
                                <span class="text-[10px] text-on-surface-variant">${timeStr}</span>
                            </div>
                            <h5 class="text-xs text-on-surface mt-1">${n.title}</h5>
                            <p class="text-[11px] text-on-surface-variant line-clamp-2">${n.message}</p>
                            ${!n.isRead ? `<button data-id="${n.id}" class="mark-read-item-btn text-[10px] text-primary hover:underline bg-transparent border-0 cursor-pointer self-start p-0 mt-1 font-label-sm">Đánh dấu đã đọc</button>` : ''}
                        `;

                        // Mark as read click event
                        const markBtn = item.querySelector('.mark-read-item-btn');
                        if (markBtn) {
                            markBtn.addEventListener('click', async (e) => {
                                e.stopPropagation();
                                await markAsRead(n.id);
                            });
                        }

                        // Clicking item marks as read and redirects if applicable
                        item.addEventListener('click', async () => {
                            if (!n.isRead) {
                                await markAsRead(n.id);
                            }
                            if (n.type === 'Order' && n.referenceId) {
                                window.location.href = `/Order/Details/${n.referenceId}`;
                            } else {
                                window.location.href = '/Notification/Index';
                            }
                        });

                        listContainer.appendChild(item);
                    });
                } catch (e) {
                    console.error('Failed to load latest notifications', e);
                }
            }

            async function markAsRead(id) {
                try {
                    const res = await fetch(`/Notification/MarkAsRead?id=${id}`, { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        await updateUnreadCount();
                        await loadLatestNotifications();
                    }
                } catch (e) {
                    console.error('Failed to mark notification as read', e);
                }
            }

            bellBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                dropdown.classList.toggle('hidden');
                if (!dropdown.classList.contains('hidden')) {
                    loadLatestNotifications();
                }
            });

            markAllBtn.addEventListener('click', async function(e) {
                e.stopPropagation();
                try {
                    const res = await fetch('/Notification/MarkAllAsRead', { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        await updateUnreadCount();
                        await loadLatestNotifications();
                    }
                } catch (e) {
                    console.error('Failed to mark all as read', e);
                }
            });

            document.addEventListener('click', function(e) {
                if (!dropdown.classList.contains('hidden') && !dropdown.contains(e.target) && e.target !== bellBtn) {
                    dropdown.classList.add('hidden');
                }
            });

            // Initial checks
            updateUnreadCount();
            
            // === SignalR Real-time Connection ===
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/notifications")
                .withAutomaticReconnect()
                .build();

            connection.on("AdminUnreadCountChanged", function(count) {
                if (count > 0) {
                    badge.textContent = count;
                    badge.classList.remove('hidden');
                } else {
                    badge.classList.add('hidden');
                }
            });

            connection.on("ReceiveAdminNotification", function(notification) {
                // If dropdown is open, reload list
                if (!dropdown.classList.contains('hidden')) {
                    loadLatestNotifications();
                }
                
                // Show browser toast/notification if supported
                if (Notification.permission === "granted") {
                    new Notification(notification.title, { body: notification.message });
                } else if (Notification.permission !== "denied") {
                    Notification.requestPermission().then(function (permission) {
                        if (permission === "granted") {
                            new Notification(notification.title, { body: notification.message });
                        }
                    });
                }
            });

            connection.start().catch(function(err) {
                return console.error(err.toString());
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
