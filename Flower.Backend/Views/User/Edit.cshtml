@model UpdateUserDTO
@{
    ViewData["Title"] = "Sửa người dùng";
    Layout = "_LayoutAdmin";
}

<div class="space-y-lg max-w-2xl mx-auto">
    <div class="flex justify-between items-center">
        <div>
            <h3 class="text-label-sm uppercase tracking-[0.3em] text-secondary">Chỉnh sửa người dùng</h3>
            <p class="serif text-3xl font-bold">Sửa người dùng</p>
        </div>
        <a asp-action="Index" class="text-label-sm uppercase tracking-widest font-bold flex items-center gap-2 hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            Quay lại
        </a>
    </div>

    <form asp-action="Edit" method="post" class="bg-surface-container-lowest border border-outline-variant p-xl space-y-xl">
        <input type="hidden" asp-for="Id" />

        <div class="space-y-md">
            <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Họ và tên</label>
            <input asp-for="FullName" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 text-body-lg font-bold" required />
            <span asp-validation-for="FullName" class="text-error text-xs uppercase tracking-widest"></span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Tên đăng nhập</label>
                <input asp-for="Username" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3 text-label-sm tracking-widest" required />
                <span asp-validation-for="Username" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Vai trò</label>
                <select asp-for="Role" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3 text-label-sm uppercase tracking-widest font-bold">
                <option value="Admin">Quản trị viên</option>
                <option value="Editor">Biên tập viên</option>
                </select>
            </div>
        </div>

        <div class="space-y-md">
            <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Mật khẩu mới</label>
            <input asp-for="Password" type="password" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-black px-md py-3" placeholder="Nhập nếu muốn thay đổi mật khẩu..." />
            <p class="text-[10px] text-outline uppercase tracking-widest italic">Để trống nếu muốn giữ mật khẩu hiện tại.</p>
        </div>

        <div class="pt-lg border-t border-outline-variant flex gap-md">
            <button type="submit" class="bg-primary text-on-primary px-xl py-4 text-label-sm uppercase tracking-[0.2em] font-bold hover:bg-neutral-800 transition-all flex-1">
                Cập nhật
            </button>
            <a asp-action="Index" class="border border-outline px-xl py-4 text-label-sm uppercase tracking-[0.2em] font-bold hover:bg-surface-container transition-all">
                Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
