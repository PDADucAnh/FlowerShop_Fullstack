@model IEnumerable<CustomerDTO>
@{
    ViewData["Title"] = "Khách hàng";
    Layout = "_LayoutAdmin";
}

<div class="space-y-lg">
    <div class="flex justify-between items-center">
        <div>
            <h3 class="text-label-sm uppercase tracking-[0.3em] text-secondary">Quản lý khách hàng</h3>
            <p class="serif text-3xl font-bold">Khách hàng</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="bg-primary text-on-primary px-lg py-3 text-label-sm uppercase tracking-widest flex items-center gap-2 hover:bg-neutral-800 transition-all">
                <span class="material-symbols-outlined text-lg">person_add</span>
                Thêm khách hàng
            </a>
        }
    </div>

    <div class="bg-surface-container-lowest border border-outline-variant overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-outline-variant text-label-sm uppercase text-secondary tracking-widest bg-surface-container-low">
                        <th class="px-lg py-4">Khách hàng</th>
                        <th class="px-lg py-4">Liên hệ</th>
                        <th class="px-lg py-4">Địa chỉ</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th class="px-lg py-4 text-right">Thao tác</th>
                        }
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant">
                    @foreach (var c in Model)
                    {
                        <tr class="table-row-hover transition-colors">
                            <td class="px-lg py-5">
                                <div class="flex items-center gap-3">
                                    <div class="size-10 bg-surface-container-highest flex items-center justify-center font-bold text-sm">
                                        @(c.FullName?.Substring(0, 1).ToUpper() ?? "C")
                                    </div>
                                    <span class="text-body-md font-bold">@c.FullName</span>
                                </div>
                            </td>
                            <td class="px-lg py-5">
                                <div class="flex flex-col">
                                    <span class="text-body-md font-semibold">@c.Email</span>
                                    <span class="text-label-sm text-secondary uppercase">@c.Phone</span>
                                </div>
                            </td>
                            <td class="px-lg py-5 text-body-md text-on-surface-variant">@(c.Address ?? "N/A")</td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="px-lg py-5 text-right space-x-4">
                                    <a asp-action="Edit" asp-route-id="@c.Id" class="text-label-sm uppercase tracking-widest font-bold text-secondary hover:text-primary transition-colors">Sửa</a>
                                    <a asp-action="Delete" asp-route-id="@c.Id" class="text-label-sm uppercase tracking-widest font-bold text-error" onclick="return confirm('Xóa khách hàng này?')">Xóa</a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <partial name="_Pagination" />
</div>
