@model CreateCouponDTO
@{
    ViewData["Title"] = "Thêm mã giảm giá";
    Layout = "_LayoutAdmin";
}

<div class="space-y-lg max-w-4xl mx-auto">
    <div class="flex justify-between items-center">
        <div>
            <h3 class="text-label-sm uppercase tracking-[0.3em] text-secondary">Mã giảm giá</h3>
            <p class="serif text-3xl font-bold">Mã giảm giá mới</p>
        </div>
        <a asp-action="Index" class="text-label-sm uppercase tracking-widest font-bold flex items-center gap-2 hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            Quay lại
        </a>
    </div>

    <form asp-action="Create" method="post" class="bg-surface-container-lowest border border-outline-variant p-xl space-y-xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Mã giảm giá</label>
                <input asp-for="Code" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 serif text-2xl font-bold placeholder:text-outline-variant font-mono" placeholder="SUMMER2026" required />
                <span asp-validation-for="Code" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Loại giảm giá</label>
                <select asp-for="DiscountType" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3">
                    <option value="Percent">Phần trăm (%)</option>
                    <option value="FixedAmount">Số tiền cố định</option>
                </select>
            </div>
        </div>

        <div class="space-y-md">
            <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Mô tả</label>
            <input asp-for="Description" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" placeholder="Giảm giá mùa hè..." />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Giá trị giảm</label>
                <input asp-for="DiscountValue" type="number" step="0.01" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" placeholder="10" required />
                <span asp-validation-for="DiscountValue" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Giảm tối đa (để trống nếu không giới hạn)</label>
                <input asp-for="MaximumDiscountAmount" type="number" step="1000" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" placeholder="50000" />
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Đơn hàng tối thiểu</label>
                <input asp-for="MinimumOrderAmount" type="number" step="1000" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" placeholder="200000" />
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Giới hạn lượt sử dụng</label>
                <input asp-for="UsageLimit" type="number" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" placeholder="100" />
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Lượt tối đa mỗi khách hàng</label>
                <input asp-for="UsagePerCustomer" type="number" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" placeholder="1" />
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Khách hàng (ID) — để trống nếu công khai</label>
                <input asp-for="CustomerId" type="number" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" placeholder="Để trống" />
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Ngày bắt đầu</label>
                <input asp-for="StartDate" type="datetime-local" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" />
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Ngày kết thúc</label>
                <input asp-for="EndDate" type="datetime-local" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" />
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md flex items-end">
                <label class="flex items-center gap-2 cursor-pointer">
                    <input asp-for="IsPublic" type="checkbox" class="w-5 h-5 rounded border-outline-variant text-primary focus:ring-primary/20" />
                    <span class="font-body-md text-body-md text-on-surface">Công khai</span>
                </label>
            </div>
            <div class="space-y-md flex items-end">
                <label class="flex items-center gap-2 cursor-pointer">
                    <input asp-for="IsActive" type="checkbox" class="w-5 h-5 rounded border-outline-variant text-primary focus:ring-primary/20" checked />
                    <span class="font-body-md text-body-md text-on-surface">Kích hoạt ngay</span>
                </label>
            </div>
        </div>

        <div class="pt-lg border-t border-outline-variant flex gap-md">
            <button type="submit" class="bg-primary text-on-primary px-xl py-4 text-label-sm uppercase tracking-[0.2em] font-bold hover:bg-neutral-800 transition-all flex-1">
                Tạo mã giảm giá
            </button>
            <a asp-action="Index" class="border border-outline px-xl py-4 text-label-sm uppercase tracking-[0.2em] font-bold hover:bg-surface-container transition-all">
                Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
