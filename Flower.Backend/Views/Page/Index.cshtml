@model IEnumerable<PageDTO>
@{
    ViewData["Title"] = "Quản lý Trang";
    Layout = "_LayoutAdmin";
}

<div class="space-y-lg max-w-6xl mx-auto">
    <div class="flex justify-between items-center">
        <div>
            <h3 class="text-label-sm uppercase tracking-[0.3em] text-secondary">Nội dung tĩnh</h3>
            <p class="serif text-3xl font-bold">Quản lý Trang</p>
        </div>
        <a asp-action="Create" class="bg-primary text-on-primary px-lg py-3 rounded-lg font-label-md hover:opacity-90 transition-opacity flex items-center gap-2">
            <span class="material-symbols-outlined text-lg">add</span>
            Thêm trang
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-lg py-3 rounded-lg">@TempData["Success"]</div>
    }

    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden">
        <table class="w-full">
            <thead>
                <tr class="border-b border-outline-variant/30 text-label-sm uppercase tracking-widest text-secondary">
                    <th class="text-left px-lg py-4">Tiêu đề</th>
                    <th class="text-left px-lg py-4">Slug</th>
                    <th class="text-center px-lg py-4">Trạng thái</th>
                    <th class="text-right px-lg py-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="border-b border-outline-variant/15">
                        <td class="px-lg py-4 font-medium">@item.Title</td>
                        <td class="px-lg py-4 text-secondary">@item.Slug</td>
                        <td class="px-lg py-4 text-center">
                            @if (item.IsActive)
                            {
                                <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">Hoạt động</span>
                            }
                            else
                            {
                                <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">Ẩn</span>
                            }
                        </td>
                        <td class="px-lg py-4 text-right">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="text-primary hover:underline text-label-sm font-bold uppercase tracking-wider">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="text-error hover:underline text-label-sm font-bold uppercase tracking-wider ml-lg" onclick="return confirm('Xóa trang @item.Title?')">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
