@model DashboardSummaryDTO
@{
    ViewData["Title"] = "Tổng quan";
    Layout = "_LayoutAdmin";
    var charts = ViewBag.Charts as DashboardChartsDTO;
    var maxRevenue = charts?.Revenue.Data.Any() == true ? charts.Revenue.Data.Max() : 1m;
    var totalStock = Model.Inventory.InStock + Model.Inventory.LowStock + Model.Inventory.OutOfStock;
    totalStock = totalStock == 0 ? 1 : totalStock;

    string FormatCurrency(decimal value) =>
        value.ToString("#,##0") + " đ";
}

<div class="space-y-stack-lg">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h2 class="font-display-lg text-display-lg text-on-background mb-2">Tổng quan đơn hàng</h2>
            <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl">Quản lý và theo dõi tất cả đơn hàng, giao dịch và yêu cầu của khách hàng.</p>
        </div>
        <div class="flex gap-3">
            <button class="flex items-center gap-2 px-4 py-2 border border-outline-variant rounded-lg text-primary font-label-md text-label-md hover:bg-primary-container/10 transition-colors bg-surface">
                <span class="material-symbols-outlined text-[18px]">download</span>
                Xuất báo cáo
            </button>
        </div>
    </div>

    <!-- Key Metrics -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
        <div class="bg-surface-container-lowest border border-outline-variant/30 rounded-xl petal-shadow-1 p-6 space-y-4 group hover:border-primary/40 transition-all">
            <div class="flex justify-between items-start">
                <div class="space-y-1">
                    <span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest">Doanh thu hôm nay</span>
                    <p class="font-headline-sm text-headline-sm text-on-surface font-bold">@FormatCurrency(Model.Revenue.Today)</p>
                </div>
                <span class="text-on-surface-variant bg-surface-variant px-2 py-1 rounded font-label-sm text-label-sm">Tháng: @FormatCurrency(Model.Revenue.Month)</span>
            </div>
            <div class="h-16 w-full relative overflow-hidden bg-surface-container-low rounded-lg">
                <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 40">
                    <path d="M0,35 Q10,30 20,32 T40,20 T60,25 T80,10 T100,15" fill="none" stroke="#ab2c5d" stroke-width="2"></path>
                </svg>
            </div>
        </div>
        <div class="bg-surface-container-lowest border border-outline-variant/30 rounded-xl petal-shadow-1 p-6 space-y-4 group hover:border-primary/40 transition-all">
            <div class="flex justify-between items-start">
                <div class="space-y-1">
                    <span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest">Đơn hàng mới</span>
                    <p class="font-headline-sm text-headline-sm text-on-surface font-bold">@Model.Orders.New</p>
                </div>
                <span class="text-on-surface-variant bg-surface-variant px-2 py-1 rounded font-label-sm text-label-sm">Tổng: @Model.Orders.Completed hoàn thành</span>
            </div>
            <div class="h-16 w-full relative overflow-hidden bg-surface-container-low rounded-lg">
                <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 40">
                    <path d="M0,30 Q20,35 40,25 T60,15 T80,20 T100,5" fill="none" stroke="#ab2c5d" stroke-width="2"></path>
                </svg>
            </div>
        </div>
        <div class="bg-surface-container-lowest border border-outline-variant/30 rounded-xl petal-shadow-1 p-6 space-y-4 group hover:border-primary/40 transition-all">
            <div class="flex justify-between items-start">
                <div class="space-y-1">
                    <span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest">Khách hàng đang hoạt động</span>
                    <p class="font-headline-sm text-headline-sm text-on-surface font-bold">@Model.Customers.Active</p>
                </div>
                <span class="text-on-surface-variant bg-surface-variant px-2 py-1 rounded font-label-sm text-label-sm">Tổng: @Model.Customers.Total</span>
            </div>
            <div class="h-16 w-full relative overflow-hidden bg-surface-container-low rounded-lg">
                <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 40">
                    <path d="M0,38 Q25,30 50,32 T75,20 T100,18" fill="none" stroke="#ab2c5d" stroke-width="2"></path>
                </svg>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-gutter">
        <div class="xl:col-span-2 bg-surface-container-lowest border border-outline-variant/30 rounded-xl petal-shadow-1 p-6">
            <div class="flex justify-between items-center mb-stack-md">
                <h4 class="font-headline-sm text-headline-sm text-on-surface">Hiệu suất doanh thu</h4>
                <div class="flex gap-4">
                    <span class="flex items-center gap-2 font-label-sm text-label-sm text-on-surface">
                        <span class="w-2 h-2 rounded-full bg-primary"></span> @DateTime.Now.Year
                    </span>
                </div>
            </div>
            <div class="h-64 w-full bg-surface-container-low rounded-lg flex items-end justify-between px-4 py-4 relative">
                <div class="absolute inset-0 flex flex-col justify-between py-4 pointer-events-none opacity-20 px-4">
                    <div class="border-b border-outline"></div>
                    <div class="border-b border-outline"></div>
                    <div class="border-b border-outline"></div>
                    <div class="border-b border-outline"></div>
                </div>
                @if (charts?.Revenue.Data.Any() == true)
                {
                    @for (int i = 0; i < charts.Revenue.Data.Count; i++)
                    {
                        var heightPercent = maxRevenue > 0 ? (charts.Revenue.Data[i] / maxRevenue) * 85 : 0;
                        var h = Math.Max((double)heightPercent, 4);
                        <div class="w-10 bg-primary rounded-t-md hover:opacity-80 transition-opacity" style="height: @h%;" title="@FormatCurrency(charts.Revenue.Data[i])"></div>
                    }
                }
                else
                {
                    <div class="w-full text-center text-on-surface-variant font-body-md text-body-md">Chưa có dữ liệu</div>
                }
            </div>
            <div class="flex justify-between px-4 mt-3 font-label-sm text-label-sm text-on-surface-variant">
                @if (charts?.Revenue.Labels.Any() == true)
                {
                    @foreach (var label in charts.Revenue.Labels)
                    {
                        <span>@label</span>
                    }
                }
            </div>
        </div>
        <div class="bg-surface-container-lowest border border-outline-variant/30 rounded-xl petal-shadow-1 p-6 flex flex-col">
            <h4 class="font-headline-sm text-headline-sm text-on-surface mb-stack-md">Phân bố tồn kho</h4>
            <div class="flex-1 flex flex-col justify-center gap-5">
                @{
                    var inStockPercent = (double)Model.Inventory.InStock / totalStock * 100;
                    var lowStockPercent = (double)Model.Inventory.LowStock / totalStock * 100;
                    var outOfStockPercent = (double)Model.Inventory.OutOfStock / totalStock * 100;
                }
                <div class="space-y-2">
                    <div class="flex justify-between font-label-sm text-label-sm text-on-surface">
                        <span>Còn hàng</span>
                        <span>@inStockPercent.ToString("0")%</span>
                    </div>
                    <div class="w-full h-1.5 bg-surface-container rounded-full overflow-hidden">
                        <div class="h-full bg-primary rounded-full" style="width: @inStockPercent%;"></div>
                    </div>
                </div>
                <div class="space-y-2">
                    <div class="flex justify-between font-label-sm text-label-sm text-on-surface">
                        <span>Sắp hết</span>
                        <span>@lowStockPercent.ToString("0")%</span>
                    </div>
                    <div class="w-full h-1.5 bg-surface-container rounded-full overflow-hidden">
                        <div class="h-full bg-warning rounded-full" style="width: @lowStockPercent%; background: #f59e0b;"></div>
                    </div>
                </div>
                <div class="space-y-2">
                    <div class="flex justify-between font-label-sm text-label-sm text-on-surface">
                        <span>Hết hàng</span>
                        <span>@outOfStockPercent.ToString("0")%</span>
                    </div>
                    <div class="w-full h-1.5 bg-surface-container rounded-full overflow-hidden">
                        <div class="h-full bg-error rounded-full" style="width: @outOfStockPercent%;"></div>
                    </div>
                </div>
            </div>
            <a asp-controller="Product" asp-action="Index" class="mt-stack-md font-label-sm text-label-sm text-primary border-b border-primary self-start pb-1 no-underline hover:opacity-80 transition-opacity">Xem toàn bộ kho hàng</a>
        </div>
    </div>
</div>
