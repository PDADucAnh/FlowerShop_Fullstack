@model UpdateProductDTO
@{
    ViewData["Title"] = "Sửa sản phẩm";
    Layout = "_LayoutAdmin";
}

<div class="space-y-lg max-w-4xl mx-auto">
    <div class="flex justify-between items-center">
        <div>
            <h3 class="text-label-sm uppercase tracking-[0.3em] text-secondary">Chỉnh sửa sản phẩm</h3>
            <p class="serif text-3xl font-bold">Sửa sản phẩm</p>
        </div>
        <a asp-action="Index" class="text-label-sm uppercase tracking-widest font-bold flex items-center gap-2 hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            Quay lại
        </a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="bg-surface-container-lowest border border-outline-variant p-xl space-y-xl">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImageUrl" />

        <div class="grid grid-cols-1 md:grid-cols-3 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">SKU</label>
                <input asp-for="Sku" id="field-sku" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 serif text-xl font-bold placeholder:text-outline-variant font-mono" placeholder="Tự động tạo" />
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Tên sản phẩm</label>
                <input asp-for="Name" id="field-name" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 serif text-2xl font-bold" required />
                <span asp-validation-for="Name" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Slug</label>
                <input asp-for="Slug" id="field-slug" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3 font-mono" placeholder="ten-san-pham" />
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Danh mục</label>
                <select asp-for="CategoryProductId" asp-items="ViewBag.CategoryProductList" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3 text-label-sm uppercase tracking-widest"></select>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Cập nhật hình ảnh</label>
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.ImageUrl" class="h-20 w-auto border border-outline-variant object-cover" />
                    </div>
                }
                <input type="file" name="uploadImage" class="w-full text-label-sm uppercase tracking-widest file:mr-lg file:py-2 file:px-lg file:border-0 file:bg-primary file:text-on-primary hover:file:bg-neutral-800" />
                <p class="text-[10px] text-outline uppercase tracking-widest italic">Để trống nếu muốn giữ ảnh hiện tại.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Giá (VND)</label>
                <input asp-for="Price" id="field-price" type="text" inputmode="numeric" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3 font-bold serif text-xl" required />
                <span asp-validation-for="Price" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Số lượng tồn kho</label>
                <input asp-for="StockQuantity" type="number" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3 font-bold serif text-xl" required />
                <span asp-validation-for="StockQuantity" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
        </div>

        <div class="space-y-md">
            <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Mô tả</label>
            <textarea asp-for="Description" rows="6" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 text-body-lg leading-relaxed italic serif"></textarea>
            <span asp-validation-for="Description" class="text-error text-xs uppercase tracking-widest"></span>
        </div>

        <div class="pt-lg border-t border-outline-variant flex gap-md">
            <button type="submit" class="bg-primary text-on-primary px-xl py-4 text-label-sm uppercase tracking-[0.2em] font-bold hover:bg-neutral-800 transition-all flex-1">
                Lưu thay đổi
            </button>
            <a asp-action="Index" class="border border-outline px-xl py-4 text-label-sm uppercase tracking-[0.2em] font-bold hover:bg-surface-container transition-all">
                Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function generateSlug(text) {
            const map = {
                'à':'a','á':'a','ạ':'a','ả':'a','ã':'a',
                'â':'a','ầ':'a','ấ':'a','ậ':'a','ẩ':'a','ẫ':'a',
                'ă':'a','ằ':'a','ắ':'a','ặ':'a','ẳ':'a','ẵ':'a',
                'è':'e','é':'e','ẹ':'e','ẻ':'e','ẽ':'e',
                'ê':'e','ề':'e','ế':'e','ệ':'e','ể':'e','ễ':'e',
                'ì':'i','í':'i','ị':'i','ỉ':'i','ĩ':'i',
                'ò':'o','ó':'o','ọ':'o','ỏ':'o','õ':'o',
                'ô':'o','ồ':'o','ố':'o','ộ':'o','ổ':'o','ỗ':'o',
                'ơ':'o','ờ':'o','ớ':'o','ợ':'o','ở':'o','ỡ':'o',
                'ù':'u','ú':'u','ụ':'u','ủ':'u','ũ':'u',
                'ư':'u','ừ':'u','ứ':'u','ự':'u','ử':'u','ữ':'u',
                'ỳ':'y','ý':'y','ỵ':'y','ỷ':'y','ỹ':'y',
                'đ':'d','Đ':'d'
            };
            let result = '';
            for (const ch of text) result += map[ch] || ch;
            return result.toLowerCase()
                .replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-')
                .replace(/-+/g, '-').replace(/^-|-$/g, '');
        }

        function formatPriceInput(input) {
            let v = input.value.replace(/\s/g, '');
            if (v) input.value = v.replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
        }

        document.addEventListener('DOMContentLoaded', function () {
            const nameInput = document.getElementById('field-name');
            const slugInput = document.getElementById('field-slug');
            const priceInput = document.getElementById('field-price');

            const origSlug = slugInput.value;
            nameInput.addEventListener('input', function () {
                if (slugInput.value === generateSlug(this.dataset.lastVal || origSlug)) {
                    slugInput.value = generateSlug(this.value);
                }
                this.dataset.lastVal = this.value;
            });
            nameInput.dataset.lastVal = nameInput.value;

            if (priceInput) {
                priceInput.addEventListener('input', function () { formatPriceInput(this); });
                priceInput.closest('form').addEventListener('submit', function () {
                    priceInput.value = priceInput.value.replace(/\s/g, '');
                });
            }
        });
    </script>
}
