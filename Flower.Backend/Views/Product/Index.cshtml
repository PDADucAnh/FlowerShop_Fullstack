@model IEnumerable<ProductDTO>
@{
    ViewData["Title"] = "Products";
    Layout = "_LayoutAdmin";
}

<div class="space-y-lg">
    <div class="flex justify-between items-center">
        <div>
            <h3 class="text-label-sm uppercase tracking-[0.3em] text-secondary">Inventory Management</h3>
            <p class="serif text-3xl font-bold">Curated Collection</p>
        </div>
        <a asp-action="Create" class="bg-primary text-on-primary px-lg py-3 text-label-sm uppercase tracking-widest flex items-center gap-2 hover:bg-neutral-800 transition-all">
            <span class="material-symbols-outlined text-lg">add</span>
            Add New Product
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-lg">
        @foreach (var product in Model)
        {
            <div class="bg-surface-container-lowest border border-outline-variant overflow-hidden group hover:border-primary transition-all flex flex-col">
                <div class="aspect-[3/4] overflow-hidden bg-surface-container-low">
                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                    {
                        <img src="@product.ImageUrl" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" />
                    }
                    else
                    {
                        <div class="w-full h-full flex items-center justify-center text-outline">
                            <span class="material-symbols-outlined text-4xl">image</span>
                        </div>
                    }
                </div>
                <div class="p-lg flex-1 flex flex-col space-y-md">
                    <div class="space-y-1">
                        <p class="text-[10px] text-secondary uppercase tracking-[0.2em]">@(product.CategoryProductName ?? "Uncategorized")</p>
                        <h4 class="serif text-lg font-bold">@product.Name</h4>
                    </div>
                    <div class="flex justify-between items-end flex-1">
                        <p class="text-body-lg font-bold">@product.Price.ToString("N0") đ</p>
                        <p class="text-label-sm text-secondary">Stock: @product.StockQuantity</p>
                    </div>
                    <div class="flex gap-md pt-4 border-t border-outline-variant">
                        <a asp-action="Details" asp-route-id="@product.Id" class="text-label-sm uppercase tracking-widest font-bold border-b border-primary pb-1">View</a>
                        <a asp-action="Edit" asp-route-id="@product.Id" class="text-label-sm uppercase tracking-widest font-bold text-secondary hover:text-primary transition-colors">Edit</a>
                        <a asp-action="Delete" asp-route-id="@product.Id" class="text-label-sm uppercase tracking-widest font-bold text-error ml-auto" onclick="return confirm('Delete this product?')">Delete</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
